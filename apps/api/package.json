    "jsonwebtoken": "^9.0.2",
    "pg": "^8.16.0",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.15.0",
    "@types/pg": "^8.15.0",
    "@types/swagger-ui-express": "^4.1.7",
    "@vitest/coverage-v8": "3.2.6",
    "openapi-types": "^12.1.3",
